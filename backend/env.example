# Configuration email pour le changement de mot de passe
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
# Alias accepté par certains contrôleurs
EMAIL_PASSWORD=your-app-password

# Base de données PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/airfawers_db"

# Serveur
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Sécurité — OBLIGATOIRE en production (clé longue aléatoire)
JWT_SECRET=change-me-in-production

# CORS — URL(s) du frontend Vercel, séparées par des virgules
# Exemple : https://airfawers-auto.vercel.app,https://www.votredomaine.com
CORS_ORIGIN=http://localhost:5173
